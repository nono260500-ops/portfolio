{
  "buildCommand": "pnpm install && pnpm -w run deploy:build",
  "outputDirectory": "artifacts/api-server/dist",
  "functions": {
    "vercel.mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/vercel.mjs" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
