# ============================================================
# PORTFOLIO — Configuration locale
# Copiez ce fichier : cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# BASE DE DONNÉES PostgreSQL
# Fonctionne avec n'importe quel hébergeur PostgreSQL
# ----------------------------------------------------------

# Option 1 — Local avec docker-compose (recommandé pour débuter)
DATABASE_URL=postgresql://postgres:password@localhost:5432/portfolio

# Option 2 — Neon (gratuit, cloud) → https://neon.tech
# DATABASE_URL=postgresql://user:password@xxxx.neon.tech/neondb?sslmode=require

# Option 3 — Supabase (gratuit, cloud) → https://supabase.com
# DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Option 4 — Railway → https://railway.app
# DATABASE_URL=postgresql://user:password@xxxx.railway.app:5432/railway

# Option 5 — PostgreSQL local (Homebrew)
# DATABASE_URL=postgresql://localhost:5432/portfolio

# ----------------------------------------------------------
# SERVEUR
# ----------------------------------------------------------
PORT=3001
BASE_PATH=/api
NODE_ENV=development

# ----------------------------------------------------------
# SESSION
# Changez cette valeur en production !
# ----------------------------------------------------------
SESSION_SECRET=dev-secret-local-change-in-production
